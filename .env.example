# ── FreshVision AI — Environment Variables ───────────────────────────────────
# Copy to .env before running.  start.sh does this automatically.

# REQUIRED — change this to a random 64-char hex string in production.
# Every login/session token is signed with this secret, so it must be kept
# private and unique per deployment.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
FRESHVISION_JWT_SECRET=CHANGE-ME-IN-PRODUCTION

# Set to "production" to enable stricter behaviour: the app refuses to start
# if FRESHVISION_JWT_SECRET is still the placeholder above.
ENVIRONMENT=development

# ── Database ──────────────────────────────────────────────────────────────
# Leave unset for local SQLite (file created automatically under ./storage).
# For PostgreSQL (Railway / Render / Supabase / Neon, etc.) set the connection
# string here. postgres:// and postgresql:// are both accepted and are
# automatically upgraded to the asyncpg driver.
#   DATABASE_URL=postgresql://user:password@host:5432/dbname
# DATABASE_URL=

# ── Accounts ──────────────────────────────────────────────────────────────
# Each account's inspections/history/analytics are fully private — no user
# can see another user's data (only role="admin" accounts see everything).

# Allow anyone to create their own account via the "Sign up" screen.
# Set to "false" to lock the app down to admin-created accounts only.
ALLOW_REGISTRATION=true

# Role assigned to new self-service sign-ups (do not set this to "admin").
DEFAULT_USER_ROLE=inspector

# Seed the two demo accounts (admin/freshvision2024, inspector/inspect123)
# on first boot when the users table is empty. Turn this OFF for any
# deployment that's reachable by other people — register real accounts
# instead, since the demo password is public (it's in this file!).
SEED_DEMO_USERS=true

# YOLO model file (relative to backend dir, or absolute path)
# Default: yolov8n.pt (auto-downloaded, ~6 MB, CPU-friendly)
# Intel speedup: run scripts/export_openvino.py then use the path below
# FRESHVISION_YOLO_WEIGHTS=yolov8n_openvino/yolov8n.xml
FRESHVISION_YOLO_WEIGHTS=yolov8n.pt

# Ports (change if 80/443 are in use)
HTTP_PORT=80
HTTPS_PORT=443

# Logging level: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost,http://localhost:80,https://localhost

# JWT token expiry (minutes, default 12h)
JWT_EXPIRE_MINUTES=720

# Inference tuning for i3 (leave as-is for i3 11th gen)
OMP_NUM_THREADS=2
OPENBLAS_NUM_THREADS=2
MKL_NUM_THREADS=2
INFERENCE_THREADS=2
YOLO_IMGSZ=320
YOLO_CONF_THRESHOLD=0.35
