# ── FreshVision AI Backend — Environment Variables ───────────────────────────
# Copy to .env for local runs, or set these as Secrets/Variables in your
# hosting provider's dashboard (Hugging Face Spaces, Railway, Render, ...).

# REQUIRED — random secret used to sign login/session tokens.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
FRESHVISION_JWT_SECRET=CHANGE-ME-IN-PRODUCTION

# Set to "production" on any public deployment. The app will refuse to boot
# if FRESHVISION_JWT_SECRET is still the placeholder value above.
ENVIRONMENT=production

# ── Database ──────────────────────────────────────────────────────────────
# Local SQLite is used automatically if this is left unset.
# For Postgres (e.g. Supabase, used by the Hugging Face Space deploy), use
# the connection string from your provider. Both postgres:// and
# postgresql:// schemes are accepted — they're auto-upgraded to asyncpg.
#   DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=

# ── Supabase Storage (optional — for image/overlay storage instead of local disk) ──
SUPABASE_URL=
SUPABASE_KEY=

# ── Accounts ──────────────────────────────────────────────────────────────
# Each user's inspections, history, and analytics are private to that
# account; only role="admin" accounts can see everyone's data.
ALLOW_REGISTRATION=true
DEFAULT_USER_ROLE=inspector

# Seed the built-in demo accounts on first boot (admin/freshvision2024,
# inspector/inspect123). Turn this OFF once you have real accounts — the
# demo password is public.
SEED_DEMO_USERS=false

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=https://your-frontend.vercel.app

# ── Tokens & rate limiting ──────────────────────────────────────────────────
JWT_EXPIRE_MINUTES=720
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_INSPECT=30/minute

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Inference tuning (safe defaults for small/free-tier CPUs) ──────────────
OMP_NUM_THREADS=2
OPENBLAS_NUM_THREADS=2
MKL_NUM_THREADS=2
INFERENCE_THREADS=2
YOLO_IMGSZ=320
YOLO_CONF_THRESHOLD=0.35
